[
{%- for post in site.posts -%}
{
  "title": {{ post.title | strip_html | jsonify }},
  "url": {{ post.url | jsonify }},
  "raw_content": {{ post.content | strip_html | jsonify }},
  "lang": {{ post.lang | default: 'zh' | jsonify }}
}{% unless forloop.last %},{% endunless %}
{%- endfor -%}
]